{
    "name": "otas/mediable",
    "description": "a laravel package to handle dealing with storing, updating or deleting files",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ahmed Mabrouk",
            "email": "a.mabrouk25@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "laravel/framework": ">=8.0",
        "otas/translatable": ">=1.0",
        "otas/filterable": ">=1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0@dev"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Otas\\Mediable\\MediableServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Otas\\Mediable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
